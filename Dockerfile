# 1. ใช้ Node.js version 18 เป็นพื้นฐาน
FROM node:18

# 2. สร้างโฟลเดอร์ทำงานในเครื่องจำลอง
WORKDIR /usr/src/app

# 3. ก๊อปปี้ไฟล์รายชื่อ library ไปวาง
COPY package*.json ./

# 4. สั่งติดตั้ง library (เหมือนที่เราพิมพ์ในเครื่องตัวเอง)
RUN npm install

# 5. ก๊อปปี้โค้ดทั้งหมด (server.js และอื่นๆ) เข้าไป
COPY . .

# 6. บอกว่าเว็บนี้จะใช้ Port อะไร (ปกติ Render จะใช้ 10000 หรือตามที่เราตั้งใน code)
EXPOSE 3000

# 7. คำสั่งสุดท้ายที่จะให้เครื่องรันเว็บทำงาน
CMD [ "node", "server.js" ]